# --- Legacy CLI (SQLite) ---
SDR_DB_PATH=./sdr.db

# --- Backend (PostgreSQL + Redis) ---
# Use port 5433 if `docker compose` maps Postgres to 5433 (avoids conflict with a local 5432).
DATABASE_URL=postgresql+asyncpg://sdr:sdr@localhost:5433/sdr
REDIS_URL=redis://localhost:6379/0

# Email verification (backend: /api/v1/verify-email, /find-and-verify)
# VERIFIER_PROVIDER: own_api | hunter | millionverifier
# - own_api: set OWN_VERIFIER_URL to your POST endpoint, or leave empty for stub (status=unknown)
# - hunter / millionverifier: set the matching API key below
VERIFIER_PROVIDER=own_api
OWN_VERIFIER_URL=
OWN_VERIFIER_API_KEY=
MILLIONVERIFIER_API_KEY=

# Optional: CLI enrichment + Hunter verify when VERIFIER_PROVIDER=hunter
APOLLO_API_KEY=
HUNTER_API_KEY=

# Product Hunt GraphQL API (optional — https://api.producthunt.com/v2/docs)
PRODUCT_HUNT_ACCESS_TOKEN=

# Scraping politeness
SDR_YC_REQUEST_DELAY=0.5
SDR_USER_AGENT=Mozilla/5.0 (compatible; SDR-Scraper/0.1; +https://example.com)
